#!/bin/sh
set -eu

target="${1:-}"
[ -n "$target" ] || exit 2

DOME_CLI="${DOME_CLI:-/opt/homebrew/bin/dome}"
if [ ! -x "$DOME_CLI" ]; then
  DOME_CLI="/Applications/Dome.app/Contents/MacOS/dome"
fi
SKETCHYBAR_CLI="${SKETCHYBAR_CLI:-/opt/homebrew/bin/sketchybar}"

state_dir="${XDG_RUNTIME_DIR:-/tmp}/dome"
state_file="$state_dir/workspace-state"
mkdir -p "$state_dir"

current="$("$DOME_CLI" query workspaces 2>/dev/null | python3 -c 'import json,sys
try:
    data=json.load(sys.stdin)
except Exception:
    data=[]
for ws in data:
    if ws.get("is_focused"):
        print(ws.get("name", ""))
        break
' 2>/dev/null || true)"

previous=""
[ -f "$state_file" ] && previous="$(sed -n '2p' "$state_file" 2>/dev/null || true)"

if [ -n "$current" ] && [ "$current" != "$target" ]; then
  previous="$current"
fi

if "$DOME_CLI" focus workspace "$target"; then
  {
    printf '%s\n' "$target"
    printf '%s\n' "$previous"
  } > "$state_file"

  if [ -x "$SKETCHYBAR_CLI" ]; then
    USER="${USER:-$(id -un)}"
    export USER
    "$SKETCHYBAR_CLI" --trigger dome_workspace_change FOCUSED_WORKSPACE="$target" >/dev/null 2>&1 || true
  fi
fi
