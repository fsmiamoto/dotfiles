{
  "includeCoAuthoredBy": false,
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.scripts/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cat | ~/.claude/statusline.js"
  },
  "enabledPlugins": {
    "suckless@suckless-skill": true
  },
  "extraKnownMarketplaces": {
    "suckless-skill": {
      "source": {
        "source": "github",
        "repo": "fsmiamoto/suckless-skill"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "verbose": false,
  "autoCompactEnabled": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
